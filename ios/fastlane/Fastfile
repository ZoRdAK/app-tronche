default_platform(:ios)

# App Store Connect API Key (same key as familia project)
def asc_key
  app_store_connect_api_key(
    key_id:       ENV["ASC_KEY_ID"],
    issuer_id:    ENV["ASC_ISSUER_ID"],
    key_filepath: ENV["ASC_KEY_FILEPATH"] || File.expand_path("~/.appstoreconnect/private_keys/AuthKey_#{ENV['ASC_KEY_ID']}.p8"),
  )
end

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    Dir.chdir("..") do
      sh("fvm flutter build ipa --release --export-options-plist=ios/ExportOptions.plist")
    end

    upload_to_testflight(
      api_key:                          asc_key,
      ipa:                              "../build/ios/ipa/tronche.ipa",
      skip_waiting_for_build_processing: true,
    )
  end

  desc "Sync metadata to App Store Connect (no binary)"
  lane :metadata do
    deliver(
      api_key:            asc_key,
      submit_for_review:  false,
      automatic_release:  false,
      force:              true,
      skip_binary_upload: true,
      skip_screenshots:   true,
      metadata_path:      "./fastlane/metadata",
    )
  end

  desc "Upload metadata + screenshots to App Store Connect"
  lane :screenshots do
    deliver(
      api_key:                asc_key,
      submit_for_review:      false,
      automatic_release:      false,
      force:                  true,
      skip_binary_upload:     true,
      skip_screenshots:       false,
      skip_metadata:          true,
      overwrite_screenshots:  true,
      screenshots_path:       "./fastlane/screenshots",
      precheck_include_in_app_purchases: false,
    )
  end

  desc "Build, upload and submit for App Store review"
  lane :release do
    Dir.chdir("..") do
      sh("fvm flutter build ipa --release --export-options-plist=ios/ExportOptions.plist")
    end

    deliver(
      api_key:            asc_key,
      submit_for_review:  true,
      automatic_release:  false,
      force:              true,
      skip_screenshots:   true,
      metadata_path:      "./fastlane/metadata",
      ipa:                "../build/ios/ipa/tronche.ipa",
      submission_information: {
        add_id_info_uses_idfa:             false,
        export_compliance_uses_encryption: false,
      },
      precheck_include_in_app_purchases: false,
      app_review_information: {
        first_name:    "Karl",
        last_name:     "Cosse",
        phone_number:  "+33633598852",
        email_address: "karl.cosse@gmail.com",
        review_notes:  "Application photobooth pour mariages. Créez un compte, configurez un événement, puis prenez des photos. L'app nécessite une caméra.",
      },
    )
  end
end
